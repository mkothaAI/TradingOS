{
  "$defs": {
    "RequestMeta": {
      "properties": {
        "request_id": {
          "title": "Request Id",
          "type": "string"
        },
        "as_of_date": {
          "format": "date",
          "title": "As Of Date",
          "type": "string"
        }
      },
      "required": [
        "request_id",
        "as_of_date"
      ],
      "title": "RequestMeta",
      "type": "object"
    },
    "TickerMetadata": {
      "properties": {
        "ticker": {
          "title": "Ticker",
          "type": "string"
        },
        "exchange": {
          "title": "Exchange",
          "type": "string"
        },
        "sector": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sector"
        },
        "market_cap": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Market Cap"
        },
        "lot_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lot Size"
        },
        "tradable": {
          "default": true,
          "title": "Tradable",
          "type": "boolean"
        }
      },
      "required": [
        "ticker",
        "exchange"
      ],
      "title": "TickerMetadata",
      "type": "object"
    },
    "UniverseConfig": {
      "properties": {
        "allowed_markets": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Markets",
          "type": "array"
        },
        "sector_caps": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sector Caps"
        },
        "max_universe_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Universe Size"
        }
      },
      "title": "UniverseConfig",
      "type": "object"
    }
  },
  "properties": {
    "meta": {
      "$ref": "#/$defs/RequestMeta"
    },
    "universe_config": {
      "$ref": "#/$defs/UniverseConfig"
    },
    "ticker_metadata": {
      "items": {
        "$ref": "#/$defs/TickerMetadata"
      },
      "title": "Ticker Metadata",
      "type": "array"
    }
  },
  "required": [
    "meta",
    "universe_config",
    "ticker_metadata"
  ],
  "title": "UniverseRequest",
  "type": "object"
}