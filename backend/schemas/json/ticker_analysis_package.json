{
  "$defs": {
    "EntryBias": {
      "enum": [
        "long",
        "short",
        "wait",
        "no_entry"
      ],
      "title": "EntryBias",
      "type": "string"
    },
    "EntryPlan": {
      "properties": {
        "entry_bias": {
          "$ref": "#/$defs/EntryBias"
        },
        "timing_window": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timing Window"
        },
        "capital_allocation": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capital Allocation"
        },
        "size_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/SizeInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "entry_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Entry Conditions",
          "type": "array"
        },
        "entry_triggers": {
          "items": {
            "type": "string"
          },
          "title": "Entry Triggers",
          "type": "array"
        },
        "entry_rationale": {
          "minLength": 1,
          "title": "Entry Rationale",
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        }
      },
      "required": [
        "entry_bias",
        "entry_rationale",
        "freshness",
        "evidence_context"
      ],
      "title": "EntryPlan",
      "type": "object"
    },
    "EvidenceContext": {
      "properties": {
        "ticker": {
          "minLength": 1,
          "title": "Ticker",
          "type": "string"
        },
        "analysis_id": {
          "minLength": 1,
          "title": "Analysis Id",
          "type": "string"
        },
        "verdict_ref": {
          "minLength": 1,
          "title": "Verdict Ref",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "source_links": {
          "items": {
            "$ref": "#/$defs/SourceLink"
          },
          "title": "Source Links",
          "type": "array"
        },
        "primary_topics": {
          "items": {
            "type": "string"
          },
          "title": "Primary Topics",
          "type": "array"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_window_start": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Window Start"
        },
        "evidence_window_end": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Window End"
        },
        "provenance_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provenance Summary"
        },
        "stale_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stale Reason"
        }
      },
      "required": [
        "ticker",
        "analysis_id",
        "verdict_ref",
        "freshness"
      ],
      "title": "EvidenceContext",
      "type": "object"
    },
    "FollowUpTarget": {
      "properties": {
        "target_kind": {
          "$ref": "#/$defs/FollowUpTargetKind"
        },
        "target_name": {
          "minLength": 1,
          "title": "Target Name",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "is_authoritative": {
          "default": false,
          "title": "Is Authoritative",
          "type": "boolean"
        },
        "topic_tags": {
          "items": {
            "type": "string"
          },
          "title": "Topic Tags",
          "type": "array"
        }
      },
      "required": [
        "target_kind",
        "target_name"
      ],
      "title": "FollowUpTarget",
      "type": "object"
    },
    "FollowUpTargetKind": {
      "enum": [
        "advisory_agent",
        "synthesized_verdict"
      ],
      "title": "FollowUpTargetKind",
      "type": "string"
    },
    "FreshnessEnvelope": {
      "properties": {
        "freshness_label": {
          "$ref": "#/$defs/FreshnessLabel"
        },
        "evidence_timestamp": {
          "format": "date-time",
          "title": "Evidence Timestamp",
          "type": "string"
        },
        "received_at": {
          "format": "date-time",
          "title": "Received At",
          "type": "string"
        },
        "last_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Updated At"
        },
        "delay_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delay Seconds"
        },
        "staleness_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Staleness Seconds"
        },
        "delay_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delay Reason"
        }
      },
      "required": [
        "freshness_label",
        "evidence_timestamp",
        "received_at"
      ],
      "title": "FreshnessEnvelope",
      "type": "object"
    },
    "FreshnessLabel": {
      "enum": [
        "real_time",
        "delayed",
        "stale",
        "snapshot"
      ],
      "title": "FreshnessLabel",
      "type": "string"
    },
    "InvalidationPlan": {
      "properties": {
        "invalidation_level": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invalidation Level"
        },
        "invalidation_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Invalidation Conditions",
          "type": "array"
        },
        "invalidation_triggers": {
          "items": {
            "type": "string"
          },
          "title": "Invalidation Triggers",
          "type": "array"
        },
        "invalidation_message": {
          "minLength": 1,
          "title": "Invalidation Message",
          "type": "string"
        },
        "reassessment_needed": {
          "title": "Reassessment Needed",
          "type": "boolean"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        }
      },
      "required": [
        "invalidation_message",
        "reassessment_needed",
        "freshness",
        "evidence_context"
      ],
      "title": "InvalidationPlan",
      "type": "object"
    },
    "MonitoringPlan": {
      "properties": {
        "monitoring_level": {
          "minLength": 1,
          "title": "Monitoring Level",
          "type": "string"
        },
        "monitoring_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Monitoring Conditions",
          "type": "array"
        },
        "review_frequency": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Frequency"
        },
        "alert_thresholds": {
          "items": {
            "type": "string"
          },
          "title": "Alert Thresholds",
          "type": "array"
        },
        "watch_notes": {
          "minLength": 1,
          "title": "Watch Notes",
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        }
      },
      "required": [
        "monitoring_level",
        "watch_notes",
        "freshness",
        "evidence_context"
      ],
      "title": "MonitoringPlan",
      "type": "object"
    },
    "RecommendationBlock": {
      "properties": {
        "block_id": {
          "minLength": 1,
          "title": "Block Id",
          "type": "string"
        },
        "block_type": {
          "$ref": "#/$defs/RecommendationBlockType"
        },
        "headline": {
          "minLength": 1,
          "title": "Headline",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/RecommendationStatus"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "entry_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/EntryPlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "risk_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiskPlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "invalidation_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/InvalidationPlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "monitoring_plan": {
          "anyOf": [
            {
              "$ref": "#/$defs/MonitoringPlan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "supporting_rule_ids": {
          "items": {
            "type": "string"
          },
          "title": "Supporting Rule Ids",
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        }
      },
      "required": [
        "block_id",
        "block_type",
        "headline",
        "summary",
        "status",
        "evidence_context",
        "freshness"
      ],
      "title": "RecommendationBlock",
      "type": "object"
    },
    "RecommendationBlockType": {
      "enum": [
        "entry",
        "risk",
        "invalidation",
        "monitoring"
      ],
      "title": "RecommendationBlockType",
      "type": "string"
    },
    "RecommendationStatus": {
      "enum": [
        "supportive",
        "cautionary",
        "blocking",
        "watching"
      ],
      "title": "RecommendationStatus",
      "type": "string"
    },
    "RiskPlan": {
      "properties": {
        "risk_level": {
          "minLength": 1,
          "title": "Risk Level",
          "type": "string"
        },
        "stop_loss": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Loss"
        },
        "waiting_time": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Waiting Time"
        },
        "hold_time": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hold Time"
        },
        "capital_at_risk": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capital At Risk"
        },
        "risk_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Risk Conditions",
          "type": "array"
        },
        "risk_notes": {
          "minLength": 1,
          "title": "Risk Notes",
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        }
      },
      "required": [
        "risk_level",
        "risk_notes",
        "freshness",
        "evidence_context"
      ],
      "title": "RiskPlan",
      "type": "object"
    },
    "SizeInfo": {
      "properties": {
        "allowed_qty": {
          "title": "Allowed Qty",
          "type": "integer"
        },
        "notional": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notional"
        },
        "risk_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Risk Amount"
        },
        "sizing_model_used": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sizing Model Used"
        },
        "stop_distance": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Distance"
        }
      },
      "required": [
        "allowed_qty"
      ],
      "title": "SizeInfo",
      "type": "object"
    },
    "SourceLink": {
      "properties": {
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "file": {
          "title": "File",
          "type": "string"
        },
        "line_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line Range"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "rule_id",
        "file"
      ],
      "title": "SourceLink",
      "type": "object"
    }
  },
  "properties": {
    "analysis_id": {
      "minLength": 1,
      "title": "Analysis Id",
      "type": "string"
    },
    "ticker": {
      "minLength": 1,
      "title": "Ticker",
      "type": "string"
    },
    "as_of_date": {
      "format": "date",
      "title": "As Of Date",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "symbolic_verdict_ref": {
      "minLength": 1,
      "title": "Symbolic Verdict Ref",
      "type": "string"
    },
    "evidence_context": {
      "$ref": "#/$defs/EvidenceContext"
    },
    "freshness": {
      "$ref": "#/$defs/FreshnessEnvelope"
    },
    "recommendation_blocks": {
      "items": {
        "$ref": "#/$defs/RecommendationBlock"
      },
      "title": "Recommendation Blocks",
      "type": "array"
    },
    "target_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/FollowUpTarget"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "primary_recommendation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Primary Recommendation"
    },
    "analysis_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analysis Summary"
    },
    "confidence_label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence Label"
    },
    "assumption_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Assumption Summary"
    }
  },
  "required": [
    "analysis_id",
    "ticker",
    "as_of_date",
    "generated_at",
    "symbolic_verdict_ref",
    "evidence_context",
    "freshness"
  ],
  "title": "TickerAnalysisPackage",
  "type": "object"
}