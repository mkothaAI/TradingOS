      "title": "SpreadQualitySnapshot",
      "type": "object"
    }
  },
  "properties": {
    "profile_id": {
      "minLength": 1,
      "title": "Profile Id",
      "type": "string"
    },
    "ticker": {
      "minLength": 1,
      "title": "Ticker",
      "type": "string"
    },
    "as_of_date": {
      "format": "date",
      "title": "As Of Date",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "symbolic_verdict_ref": {
      "minLength": 1,
      "title": "Symbolic Verdict Ref",
      "type": "string"
    },
    "evidence_context": {
      "$ref": "#/$defs/EvidenceContext"
    },
    "freshness": {
      "$ref": "#/$defs/FreshnessEnvelope"
    },
    "contract_snapshots": {
      "items": {
        "$ref": "#/$defs/OptionContractSnapshot"
      },
      "title": "Contract Snapshots",
      "type": "array"
    },
    "greeks_snapshots": {
      "items": {
        "$ref": "#/$defs/GreeksSnapshot"
      },
      "title": "Greeks Snapshots",
      "type": "array"
    },
    "liquidity_snapshots": {
      "items": {
        "$ref": "#/$defs/LiquiditySnapshot"
