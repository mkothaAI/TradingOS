{
  "$defs": {
    "EvidenceContext": {
      "properties": {
        "ticker": {
          "minLength": 1,
          "title": "Ticker",
          "type": "string"
        },
        "analysis_id": {
          "minLength": 1,
          "title": "Analysis Id",
          "type": "string"
        },
        "verdict_ref": {
          "minLength": 1,
          "title": "Verdict Ref",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "source_links": {
          "items": {
            "$ref": "#/$defs/SourceLink"
          },
          "title": "Source Links",
          "type": "array"
        },
        "primary_topics": {
          "items": {
            "type": "string"
          },
          "title": "Primary Topics",
          "type": "array"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_window_start": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Window Start"
        },
        "evidence_window_end": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Window End"
        },
        "provenance_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provenance Summary"
        },
        "stale_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stale Reason"
        }
      },
      "required": [
        "ticker",
        "analysis_id",
        "verdict_ref",
        "freshness"
      ],
      "title": "EvidenceContext",
      "type": "object"
    },
    "FreshnessEnvelope": {
      "properties": {
        "freshness_label": {
          "$ref": "#/$defs/FreshnessLabel"
        },
        "evidence_timestamp": {
          "format": "date-time",
          "title": "Evidence Timestamp",
          "type": "string"
        },
        "received_at": {
          "format": "date-time",
          "title": "Received At",
          "type": "string"
        },
        "last_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Updated At"
        },
        "delay_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delay Seconds"
        },
        "staleness_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Staleness Seconds"
        },
        "delay_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delay Reason"
        }
      },
      "required": [
        "freshness_label",
        "evidence_timestamp",
        "received_at"
      ],
      "title": "FreshnessEnvelope",
      "type": "object"
    },
    "FreshnessLabel": {
      "enum": [
        "real_time",
        "delayed",
        "stale",
        "snapshot"
      ],
      "title": "FreshnessLabel",
      "type": "string"
    },
    "MonitoringCondition": {
      "properties": {
        "condition_id": {
          "minLength": 1,
          "title": "Condition Id",
          "type": "string"
        },
        "condition_type": {
          "$ref": "#/$defs/MonitoringConditionType"
        },
        "condition_name": {
          "minLength": 1,
          "title": "Condition Name",
          "type": "string"
        },
        "condition_description": {
          "minLength": 1,
          "title": "Condition Description",
          "type": "string"
        },
        "trigger_basis": {
          "minLength": 1,
          "title": "Trigger Basis",
          "type": "string"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        },
        "comparison_operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comparison Operator"
        },
        "severity_hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity Hint"
        },
        "freshness": {
          "$ref": "#/$defs/FreshnessEnvelope"
        },
        "evidence_context": {
          "$ref": "#/$defs/EvidenceContext"
        }
      },
      "required": [
        "condition_id",
        "condition_type",
        "condition_name",
        "condition_description",
        "trigger_basis",
        "freshness",
        "evidence_context"
      ],
      "title": "MonitoringCondition",
      "type": "object"
    },
    "MonitoringConditionType": {
      "enum": [
        "thesis_breakage",
        "stop_loss",
        "volatility_change",
        "macro_shock",
        "options_risk_change",
        "other_observable_condition"
      ],
      "title": "MonitoringConditionType",
      "type": "string"
    },
    "MonitoringStateStatus": {
      "enum": [
        "watching",
        "stable",
        "watchlist_warning",
        "thesis_at_risk",
        "review_needed"
      ],
      "title": "MonitoringStateStatus",
      "type": "string"
    },
    "SourceLink": {
      "properties": {
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "file": {
          "title": "File",
          "type": "string"
        },
        "line_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line Range"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "rule_id",
        "file"
      ],
      "title": "SourceLink",
      "type": "object"
    }
  },
  "properties": {
    "state_id": {
      "minLength": 1,
      "title": "State Id",
      "type": "string"
    },
    "context_id": {
      "minLength": 1,
      "title": "Context Id",
      "type": "string"
    },
    "ticker": {
      "minLength": 1,
      "title": "Ticker",
      "type": "string"
    },
    "symbolic_verdict_ref": {
      "minLength": 1,
      "title": "Symbolic Verdict Ref",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/MonitoringStateStatus"
    },
    "last_checked_at": {
      "format": "date-time",
      "title": "Last Checked At",
      "type": "string"
    },
    "active_condition_ids": {
      "items": {
        "type": "string"
      },
      "title": "Active Condition Ids",
      "type": "array"
    },
    "resolved_condition_ids": {
      "items": {
        "type": "string"
      },
      "title": "Resolved Condition Ids",
      "type": "array"
    },
    "current_conditions": {
      "items": {
        "$ref": "#/$defs/MonitoringCondition"
      },
      "title": "Current Conditions",
      "type": "array"
    },
    "state_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "State Summary"
    },
    "freshness": {
      "$ref": "#/$defs/FreshnessEnvelope"
    },
    "evidence_context": {
      "$ref": "#/$defs/EvidenceContext"
    }
  },
  "required": [
    "state_id",
    "context_id",
    "ticker",
    "symbolic_verdict_ref",
    "status",
    "last_checked_at",
    "freshness",
    "evidence_context"
  ],
  "title": "MonitoringState",
  "type": "object"
}